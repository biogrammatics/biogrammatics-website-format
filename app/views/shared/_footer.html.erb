<div class="mx-auto max-w-7xl px-4 py-16 grid md:grid-cols-4 gap-10">
  <div>
    <div class="text-xl font-semibold">Business Name</div>
    <div class="mt-3 text-sm text-slate-300">
      500 Terry Francine St.<br>San Francisco, CA 94158<br>123-456-7890<br>
      <a href="mailto:info@mysite.com" class="underline">info@mysite.com</a>
    </div>
  </div>

  <div>
    <div class="font-semibold">Menu</div>
    <ul class="mt-3 space-y-2 text-sm">
      <li><%= link_to "Home", root_path, class: "hover:text-brand-accent" %></li>
      <li><%= link_to "About", about_path, class: "hover:text-brand-accent" %></li>
      <li><%= link_to "Services", services_path, class: "hover:text-brand-accent" %></li>
      <li><%= link_to "Projects", projects_path, class: "hover:text-brand-accent" %></li>
    </ul>
  </div>

  <div>
    <div class="font-semibold">Socials</div>
    <ul class="mt-3 space-y-2 text-sm">
      <li><a href="#" class="underline">Facebook</a></li>
      <li><a href="#" class="underline">Instagram</a></li>
      <li><a href="#" class="underline">LinkedIn</a></li>
      <li><a href="#" class="underline">X</a></li>
    </ul>
  </div>

  <div class="md:col-span-1">
    <div class="font-semibold">Get in Touch</div>
    <%= form_with url: contact_path, scope: :contact, method: :post, class: "mt-3 grid grid-cols-2 gap-3" do |f| %>
      <%= f.text_field :first_name, required: true, placeholder: "First Name*", class: "col-span-1 rounded-md bg-slate-800 border border-white/10 p-3" %>
      <%= f.text_field :last_name, required: true, placeholder: "Last Name*", class: "col-span-1 rounded-md bg-slate-800 border border-white/10 p-3" %>
      <%= f.email_field :email, required: true, placeholder: "Email*", class: "col-span-2 rounded-md bg-slate-800 border border-white/10 p-3" %>
      <%= f.telephone_field :phone, placeholder: "Phone", class: "col-span-2 rounded-md bg-slate-800 border border-white/10 p-3" %>
      <%= f.text_field :subject, placeholder: "Subject", class: "col-span-2 rounded-md bg-slate-800 border border-white/10 p-3" %>
      <%= f.text_area :message, rows: 4, placeholder: "Message", class: "col-span-2 rounded-md bg-slate-800 border border-white/10 p-3" %>
      <%= f.submit "Submit", class: "col-span-2 rounded-full bg-brand-accent text-slate-900 font-semibold py-3" %>
    <% end %>
    <p class="mt-6 text-xs text-slate-400">© <%= Time.current.year %> Business Name.</p>
  </div>
</div>
