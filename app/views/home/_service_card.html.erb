<%# locals: index:, title:, body: %>
<article class="rounded-2xl bg-slate-800 p-6 shadow hover:shadow-lg transition">
  <div class="text-4xl font-bold text-brand-accent/80"><%= "%02d" % index %></div>
  <h3 class="mt-4 text-xl font-semibold"><%= title %></h3>
  <p class="mt-2 text-slate-300 text-sm leading-6"><%= body %></p>
</article>
