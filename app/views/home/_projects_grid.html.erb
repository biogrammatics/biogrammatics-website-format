<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
  <% 12.times do |i| %>
    <div class="relative group aspect-[4/3] overflow-hidden rounded-xl bg-slate-800">
      <img src="https://picsum.photos/seed/<%= i %>/600/400" alt=""
           class="h-full w-full object-cover group-hover:scale-105 transition">
      <div class="absolute inset-0 bg-slate-900/0 group-hover:bg-slate-900/30 transition"></div>
    </div>
  <% end %>
</div>
